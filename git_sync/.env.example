# Git Sync DAG Environment Configuration
# Copy this file to your main .env file and update with your values

# Required: GitHub credentials
GITHUB_USER=your_github_username
GITHUB_TOKEN=github_pat_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Required: Comma-separated list of repositories to sync
# Format: username/repository,username/repository2
GIT_SYNC_REPOS=your_username/repo1,your_username/repo2,your_username/repo3

# Optional: Force specific branch (overrides environment-based selection)
# GIT_SYNC_BRANCH=dev

# Optional: Environment setting (determines default branch)
# development = uses 'dev' branch by default
# production = uses 'main' branch by default
ENVIRONMENT=development